# Cuenta de Discord dedicada al dispositivo (NO la cuenta real de la nena)
DISCORD_EMAIL=
DISCORD_PASSWORD=

# URL del canal de voz (copiar desde Discord: clic derecho en canal → Copiar enlace)
VOICE_CHANNEL_URL=https://discord.com/channels/1485390577670295725/1485390578144383123

# "keyboard" en Mac/desktop, "gpio" en Raspberry Pi
BUTTON_MODE=keyboard

# Solo cuando BUTTON_MODE=gpio (numero de pin BCM, no board)
GPIO_PIN=17

# Directorio donde se guarda la sesion de Discord (no hace falta cambiarlo)
USER_DATA_DIR=./discord-session

# debug | info | warn | error
LOG_LEVEL=info
DEBUG_MODE=false
